{
  "name": "@synapxlab/wysiwyg",
  "version": "1.0.0",
  "description": "WYSIWYG rich-text editor — zero runtime dependencies, TypeScript + SCSS",
  "keywords": [
    "wysiwyg", "editor", "rich-text", "contenteditable",
    "typescript", "zero-dependency", "table", "twig"
  ],
  "homepage": "https://github.com/synapxLab/wysiwyg#readme",
  "bugs": { "url": "https://github.com/synapxLab/wysiwyg/issues" },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/synapxLab/wysiwyg.git"
  },
  "license": "MIT",
  "author": "SynapxLab",
  "sideEffects": ["*.css"],
  "main": "./dist/wysiwyg.cjs.js",
  "module": "./dist/wysiwyg.es.js",
  "types": "./dist/types/index.d.ts",
  "exports": {
    ".": {
      "types":   "./dist/types/index.d.ts",
      "import":  "./dist/wysiwyg.es.js",
      "require": "./dist/wysiwyg.cjs.js"
    },
    "./dist/wysiwyg.css": "./dist/wysiwyg.css"
  },
  "files": [
    "dist",
    "LICENSE",
    "README.md"
  ],
  "engines": { "node": ">=14.0.0" },
  "scripts": {
    "dev":            "vite",
    "build":          "vite build",
    "build:lib":      "vite build --config vite.lib.config.ts && tsc -p tsconfig.build.json",
    "build:types":    "tsc -p tsconfig.build.json",
    "preview":        "vite preview",
    "prepublishOnly": "npm run build:lib"
  },
  "devDependencies": {
    "sass":       "^1.97.3",
    "typescript": "^5.0.0",
    "vite":       "^7.3.1"
  }
}
