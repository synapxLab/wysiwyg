{
  "name": "@synapxlab/wysiwyg",
  "version": "1.3.1",
  "description": "WYSIWYG rich-text editor · pagebuilder — native SVG drawing, KaTeX math, zero runtime dependencies, TypeScript + SCSS",
  "keywords": [
    "wysiwyg",
    "pagebuilder",
    "editor",
    "rich-text",
    "rich-text-editor",
    "contenteditable",
    "typescript",
    "zero-dependency",
    "no-dependencies",
    "table",
    "twig",
    "katex",
    "math",
    "latex",
    "mermaid",
    "diagram",
    "svg",
    "draw",
    "vector",
    "esm",
    "cjs",
    "grid",
    "layout",
    "html-editor",
    "source-editor"
  ],
  "homepage": "https://github.com/synapxLab/wysiwyg#readme",
  "bugs": {
    "url": "https://github.com/synapxLab/wysiwyg/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/synapxLab/wysiwyg.git"
  },
  "license": "MIT",
  "author": "SynapxLab",
  "sideEffects": [
    "*.css"
  ],
  "main": "./dist/wysiwyg.cjs.js",
  "module": "./dist/wysiwyg.es.js",
  "types": "./dist/types/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/types/index.d.ts",
      "import": "./dist/wysiwyg.es.js",
      "require": "./dist/wysiwyg.cjs.js"
    },
    "./style.css": "./dist/wysiwyg.css"
  },
  "files": [
    "dist",
    "LICENSE",
    "README.md"
  ],
  "engines": {
    "node": ">=18.0.0"
  },
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "build:lib": "vite build --config vite.lib.config.ts && tsc -p tsconfig.build.json",
    "build:excalidraw": "vite build --config vite.excalidraw.config.ts",
    "build:types": "tsc -p tsconfig.build.json",
    "preview": "vite preview",
    "prepublishOnly": "npm run build:lib"
  },
  "devDependencies": {
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "chokidar": "^4.0.3",
    "detect-libc": "^2.1.2",
    "esbuild": "^0.27.3",
    "fdir": "^6.5.0",
    "immutable": "^5.1.5",
    "is-extglob": "^2.1.1",
    "is-glob": "^4.0.3",
    "mermaid": "^11.13.0",
    "nanoid": "^3.3.11",
    "node-addon-api": "^7.1.1",
    "picocolors": "^1.1.1",
    "picomatch": "^4.0.3",
    "postcss": "^8.5.8",
    "readdirp": "^4.1.2",
    "rollup": "^4.59.0",
    "sass": "^1.97.3",
    "source-map-js": "^1.2.1",
    "tinyglobby": "^0.2.15",
    "typescript": "^5.0.0",
    "vite": "^7.3.1"
  },
  "dependencies": {
    "@excalidraw/excalidraw": "^0.18.0",
    "katex": "^0.16.40",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  }
}
